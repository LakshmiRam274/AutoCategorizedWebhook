# Copy this file to ".env" and fill in your own (FREE) API key.
# The app talks to any OpenAI-compatible "chat completions" endpoint, so you
# can pick whichever free provider you have / can sign up for in seconds.
# Do NOT commit your real .env file.

# ---------------------------------------------------------------------------
# Option 1 (recommended): Groq - fast, free, no credit card required.
# Get a key at: https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------
# Option 2: OpenRouter - many models, look for ones tagged ":free"
# Get a key at: https://openrouter.ai/keys
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
# LLM_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------------------
# Option 3: Google Gemini (OpenAI-compatible endpoint)
# Get a key at: https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-1.5-flash
# LLM_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Option 4: Local Ollama - fully free & offline, no key required.
# Install from https://ollama.com and run: ollama pull llama3.1
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=ollama

# ---------------------------------------------------------------------------
# Optional tuning
# LLM_TIMEOUT=30
# LLM_JSON_MODE=true
# SAMPLES_FILE=data/samples.json
# LOG_FILE=logs/predictions.jsonl
